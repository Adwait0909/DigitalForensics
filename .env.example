# ─── DFEMS Environment Configuration ────────────────────────────────────────
# Copy this to .env and fill in real values. NEVER commit .env to version control.

# Flask
FLASK_APP=app.py
FLASK_DEBUG=false
SECRET_KEY=change-this-to-a-long-random-secret

# Database (MySQL)
DATABASE_URL=mysql+pymysql://dfems_user:dfems_pass@localhost/dfems_db

# JWT
JWT_SECRET_KEY=change-this-jwt-secret-too
JWT_COOKIE_SECURE=false   # set true in production (HTTPS only)

# File upload
# UPLOAD_FOLDER is derived from the app directory by default

